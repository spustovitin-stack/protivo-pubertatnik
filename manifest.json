{
  "manifest_version": 3,
  "name": "Анти-Пубертат Редирект PRO",
  "version": "2.0",
  "description": "Интерфейс управления блокировками с защитой дефолтных сайтов.",
  "permissions": [
    "storage",
    "tabs",
    "favicon"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
